# Database connection
# For local dev: use localhost. For Docker: the service name (db) is used in docker-compose.yml.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=personal_expense

# Optional override. If set, takes precedence over POSTGRES_*.
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/personal_expense

# Preferred format: JSON list of allowed origins
CORS_ORIGINS=["http://localhost:5173"]

# Environment: "development" enables debug logging; "production" for deployed use
APP_ENV=development

# DB readiness wait settings (used by docker migration/startup flow)
WAIT_FOR_DB_TIMEOUT=60
WAIT_FOR_DB_INTERVAL=1

# (Optional) Test database - required for running pytest
# TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/personal_expense_test
