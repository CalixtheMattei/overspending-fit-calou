# Docker Compose environment (private VPS deployment)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=personal_expense

# Optional override. If set, backend uses this instead of POSTGRES_*.
# DATABASE_URL=postgresql+psycopg://postgres:change_me_strong_password@db:5432/personal_expense

APP_ENV=production
# Preferred format: JSON list
CORS_ORIGINS=["https://your-domain.example.com"]

WAIT_FOR_DB_TIMEOUT=60
WAIT_FOR_DB_INTERVAL=1

# Optional local bind ports for host-level Nginx upstreams
FRONTEND_HOST_PORT=5173
BACKEND_HOST_PORT=8000
MCP_HOST_PORT=3001

# ── Demo deployment (public read-only) ──────────────────────────
# Used by docker-compose.demo.yml. Store actual values in
# /etc/overspending-fit-calou/demo.env (never commit real passwords).
POSTGRES_PASSWORD_DEMO_ADMIN=
POSTGRES_PASSWORD_DEMO_APP=
BACKEND_HOST_PORT_DEMO=8001
FRONTEND_HOST_PORT_DEMO=5174
